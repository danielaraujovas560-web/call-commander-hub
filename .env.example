# ============================================================
# Painel PABX — variáveis de ambiente
# Copie este arquivo para `.env` e preencha com seus valores.
# ============================================================

# ---------- Supabase (frontend / cliente) ----------
# Expostas ao bundle do navegador. Use a chave PUBLISHABLE (anon), nunca a service_role.
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
VITE_SUPABASE_PROJECT_ID="seu-project-ref"

# ---------- Supabase (servidor / SSR) ----------
# Mesmos valores acima, sem o prefixo VITE_, para serverFns e SSR.
SUPABASE_URL="https://SEU-PROJETO.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_PROJECT_ID="seu-project-ref"

# Service role — SECRETO. Apenas no servidor. Bypassa RLS.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# ---------- Mini-agente PABX ----------
# URL HTTPS pública do agente que roda no servidor Asterisk.
PABX_AGENT_URL="https://meuservidor.duckdns.org"
# Segredo HMAC compartilhado entre o painel e o agente (hex de 32+ bytes).
PABX_AGENT_SECRET="troque-por-um-hex-aleatorio-de-64-caracteres"
