# ===== Conexão com seu MariaDB do Asterisk =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=asterisk
DB_PASSWORD=troque-isto
DB_NAME=asterisk

# ===== HMAC compartilhado com o painel Lovable =====
# Use a MESMA string que você cadastrou em PABX_AGENT_SECRET no Lovable.
AGENT_SECRET=troque-por-uma-string-aleatoria-longa

# Janela anti-replay (segundos)
SIGNATURE_WINDOW=300

# Porta do agente
PORT=8787
